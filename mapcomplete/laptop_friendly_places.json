      },
      "mappings": [
        { "if": "indoor_seating=yes", "then": { "en": "There is indoor seating" } },
        { "if": "indoor_seating=no", "then": { "en": "There is no indoor seating" } }
      ]
    },
    {
      "id": "outdoor-seating",
      "question": { "en": "Does this place have outdoor seating?" },
      "questionHint": {
        "en": "See <a href=\"https://wiki.openstreetmap.org/wiki/Key:outdoor_seating\" target=\"_blank\">Key:outdoor_seating</a> on the OSM wiki"
      },
      "mappings": [
        { "if": "outdoor_seating=yes", "then": { "en": "There is outdoor seating" } },
        { "if": "outdoor_seating=no", "then": { "en": "There is no outdoor seating" } }
      ]
    },
    {
      "id": "smoking",
      "question": { "en": "Is smoking allowed at this place?" },
      "questionHint": {
        "en": "See <a href=\"https://wiki.openstreetmap.org/wiki/Key:smoking\" target=\"_blank\">Key:smoking</a> on the OSM wiki"
      },
      "mappings": [
        { "if": "smoking=yes", "then": { "en": "Smoking is allowed" } },
        { "if": "smoking=no", "then": { "en": "Smoking is not allowed" } },
        { "if": "smoking=outside", "then": { "en": "Smoking is only allowed outside" } },
        { "if": "smoking=separated", "then": { "en": "Smoking is only allowed in a separated area" } }
      ]
    },
    {
      "id": "level",
      "question": { "en": "On what floor is this place located?" },
      "questionHint": {
        "en": "Example: <i>0</i> for ground floor, <i>1</i> for first floor, <i>-1</i> for basement. See <a href=\"https://wiki.openstreetmap.org/wiki/Key:level\" target=\"_blank\">Key:level</a> on the OSM wiki"
      },
      "render": { "en": "Located on floor {level}" },
      "freeform": { "key": "level", "type": "float" }
    },
    "phone",
    "website",
    {
      "id": "fee",
      "question": { "en": "Is there a fee to use or enter this place?" },
      "questionHint": {
        "en": "Example: a coworking space charging for a day pass. See <a href=\"https://wiki.openstreetmap.org/wiki/Key:fee\" target=\"_blank\">Key:fee</a> on the OSM wiki"
      },
      "mappings": [
        { "if": "fee=yes", "then": { "en": "There is a fee to use or enter this place" } },
