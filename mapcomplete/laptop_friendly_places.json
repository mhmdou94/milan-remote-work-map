      "id": "reservation",
      "question": { "en": "Does one need to book ahead of time?" },
      "questionHint": {
        "en": "See <a href=\"https://wiki.openstreetmap.org/wiki/Key:reservation\" target=\"_blank\">Key:reservation</a> on the OSM wiki"
      },
      "mappings": [
        { "if": "reservation=yes", "then": { "en": "Booking ahead is required" } },
        { "if": "reservation=recommended", "then": { "en": "Booking ahead is recommended" } },
        { "if": "reservation=no", "then": { "en": "Booking ahead is not necessary" } }
      ]
    },
    {
      "id": "capacity",
      "question": { "en": "How many people/seats/desks fit here?" },
      "questionHint": {
        "en": "Example: <i>20</i>. See <a href=\"https://wiki.openstreetmap.org/wiki/Key:capacity\" target=\"_blank\">Key:capacity</a> on the OSM wiki"
      },
      "render": { "en": "Room for {capacity} people" },
