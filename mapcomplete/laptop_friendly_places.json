{
  "id": "laptop_friendly_places",
  "name": {
    "en": "Laptop friendly places"
  },
  "description": {
    "en": "Cafés, libraries, coworking spaces and other places that are tagged as friendly (or unfriendly) towards people working on a laptop."
  },
  "credits": "a1ca424",
  "credits:uid": 1914637,
  "minzoom": 15,
  "source": {
    "osmTags": {
      "or": [
        "laptop=yes",
        "laptop=no",
        "laptop=restricted"
      ]
    }
  },
  "title": {
    "render": "{name}"
  },
  "pointRendering": [
    {
      "location": [
        "point",
        "centroid"
      ],
      "marker": [
        {
          "icon": "circle",
          "color": {
            "render": "#f59e0b",
            "mappings": [
              { "if": "laptop=yes", "then": "#22c55e" },
              { "if": "laptop=no", "then": "#ef4444" },
              { "if": "laptop=restricted", "then": "#f59e0b" }
            ]
          }
        }
      ]
    }
  ],
  "lineRendering": [
    {
      "width": 1,
      "color": {
        "render": "#f59e0b",
        "mappings": [
          { "if": "laptop=yes", "then": "#22c55e" },
          { "if": "laptop=no", "then": "#ef4444" },
          { "if": "laptop=restricted", "then": "#f59e0b" }
        ]
      }
    }
  ],
  "presets": [
    {
      "title": { "en": "a laptop-friendly café" },
      "tags": ["amenity=cafe", "laptop=yes"]
    },
    {
      "title": { "en": "a laptop-friendly bar" },
      "tags": ["amenity=bar", "laptop=yes"]
    },
    {
      "title": { "en": "a coworking space" },
      "tags": ["amenity=coworking_space", "laptop=yes"]
    },
    {
      "title": { "en": "a library" },
      "tags": ["amenity=library", "laptop=yes"]
    }
  ],
  "tagRenderings": [
    {
      "id": "laptop",
      "question": { "en": "Is working on a laptop welcome here?" },
      "questionHint": {
        "en": "See <a href=\"https://taginfo.openstreetmap.org/keys/laptop\" target=\"_blank\">taginfo: laptop</a> for how this tag is used"
      },
      "mappings": [
        { "if": "laptop=yes", "then": { "en": "Working on a laptop is welcome here" } },
        { "if": "laptop=no", "then": { "en": "Working on a laptop is <b>not</b> allowed here" } },
        {
          "if": "laptop=restricted",
          "then": { "en": "Working on a laptop is allowed, but with some restrictions" }
        }
      ]
    },
    {
      "id": "laptop-conditional",
      "condition": "laptop=restricted",
      "question": { "en": "What are the restrictions on using a laptop here?" },
      "questionHint": {
        "en": "Example: <i>no @ (12:00-14:00)</i> for \"not allowed during lunch hours\". See <a href=\"https://wiki.openstreetmap.org/wiki/Conditional_restrictions\" target=\"_blank\">Conditional restrictions</a> on the OSM wiki"
      },
      "render": { "en": "Restrictions: {laptop:conditional}" },
      "freeform": { "key": "laptop:conditional", "type": "string" }
    },
    {
      "id": "internet-access",
      "question": { "en": "Does this place offer internet access?" },
      "questionHint": {
        "en": "See <a href=\"https://wiki.openstreetmap.org/wiki/Key:internet_access\" target=\"_blank\">Key:internet_access</a> on the OSM wiki"
      },
      "mappings": [
        { "if": "internet_access=yes", "then": { "en": "Internet access is available" } },
        { "if": "internet_access=wlan", "then": { "en": "Wireless internet access (WiFi) is available" } },
        { "if": "internet_access=wired", "then": { "en": "Wired internet access is available" } },
        { "if": "internet_access=terminal", "then": { "en": "Internet access is available via a terminal" } },
        { "if": "internet_access=no", "then": { "en": "No internet access is available" } }
      ]
    },
    {
      "id": "wifi-ssid",
      "condition": { "or": ["internet_access=yes", "internet_access=wlan"] },
      "question": { "en": "What is the WiFi network name (SSID) at this place?" },
      "questionHint": {
        "en": "Example: <i>Starbucks WiFi</i>. See <a href=\"https://wiki.openstreetmap.org/wiki/Key:internet_access:ssid\" target=\"_blank\">Key:internet_access:ssid</a> on the OSM wiki"
      },
      "render": { "en": "The WiFi network is named <b>{internet_access:ssid}</b>" },
      "freeform": { "key": "internet_access:ssid", "type": "string" }
    },
    {
      "id": "wifi-fee",
      "condition": { "or": ["internet_access=yes", "internet_access=wlan"] },
      "question": { "en": "Is the WiFi free, paid, or only for customers?" },
      "questionHint": {
        "en": "See <a href=\"https://wiki.openstreetmap.org/wiki/Tag:internet_access=wlan\" target=\"_blank\">internet_access=wlan</a> on the OSM wiki"
      },
      "mappings": [
        { "if": "internet_access:fee=no", "then": { "en": "The WiFi is free to use" } },
        { "if": "internet_access:fee=yes", "then": { "en": "The WiFi requires payment" } },
        { "if": "internet_access:fee=customers", "then": { "en": "The WiFi is free, but only for customers" } }
      ]
    },
    {
      "id": "wifi-password",
      "condition": { "or": ["internet_access=yes", "internet_access=wlan"] },
      "question": { "en": "Is a password required to use the WiFi?" },
      "questionHint": {
        "en": "We only record whether a password is needed, never the password itself. See <a href=\"https://wiki.openstreetmap.org/wiki/Key:internet_access:password\" target=\"_blank\">Key:internet_access:password</a> on the OSM wiki"
      },
      "mappings": [
        { "if": "internet_access:password=yes", "then": { "en": "A password is required" } },
        { "if": "internet_access:password=no", "then": { "en": "No password is required" } }
      ]
    },
    {
      "id": "sockets",
      "question": { "en": "Are power sockets available to charge devices?" },
      "questionHint": {
        "en": "Example: plug sockets near tables or the bar. See <a href=\"https://wiki.openstreetmap.org/wiki/Key:power_supply\" target=\"_blank\">Key:power_supply</a> on the OSM wiki"
      },
      "mappings": [
        { "if": "sockets=yes", "then": { "en": "Power sockets are available" } },
        { "if": "sockets=many", "then": { "en": "Plenty of power sockets are available" } },
        { "if": "sockets=no", "then": { "en": "No power sockets are available" } }
      ]
    },
    "opening_hours",
    "wheelchair-access",
    {
      "id": "air-conditioning",
      "question": { "en": "Does this place have air conditioning?" },
      "questionHint": {
