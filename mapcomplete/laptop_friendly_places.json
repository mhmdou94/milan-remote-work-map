      "id": "charge",
      "condition": "fee=yes",
      "question": { "en": "How much does it cost?" },
      "questionHint": {
        "en": "Example: <i>5 EUR/day</i>. See <a href=\"https://wiki.openstreetmap.org/wiki/Key:charge\" target=\"_blank\">Key:charge</a> on the OSM wiki"
      },
      "render": { "en": "Costs <b>{charge}</b>" },
